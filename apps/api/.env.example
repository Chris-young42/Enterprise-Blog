# 运行环境：本地开发填 development，生产部署填 production
NODE_ENV=development
# 服务监听端口：本机开发保持 3000，避免与前端端口冲突
PORT=3000
# API 前缀：建议保持 api/v1，前后端默认按该前缀请求
API_PREFIX=api/v1
# 允许跨域来源：多个地址用英文逗号分隔，不允许可留空
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 服务名称：用于日志和监控展示，可按项目名自定义
APP_NAME=Enterprise Blog API
# 数据库连接串：格式 mysql://账号:密码@主机:端口/库名?schema=public
DATABASE_URL="mysql://root:root@127.0.0.1:3306/enterprise_blog?schema=public"
# JWT 访问令牌密钥：必须改成高强度随机字符串（至少 32 位）
JWT_ACCESS_SECRET="please-change-access-secret"
# JWT 刷新令牌密钥：必须改成与访问令牌不同的高强度随机字符串
JWT_REFRESH_SECRET="please-change-refresh-secret"
# JWT 访问令牌有效期：支持 1d/12h/30m 这类写法
JWT_ACCESS_EXPIRES_IN="1d"
# JWT 访问令牌有效秒数：用于统计/缓存场景，通常与上面保持一致
JWT_ACCESS_EXPIRES_IN_SECONDS=86400
# bcrypt 加密轮数：开发建议 10~12，生产建议 12 或更高
BCRYPT_SALT_ROUNDS=12
# 存储类型：LOCAL 表示本地磁盘，S3 表示对象存储
STORAGE_PROVIDER=LOCAL
# 对象存储桶名称：使用 S3/MinIO 时填写实际 bucket 名
STORAGE_BUCKET=enterprise-blog
# 文件公开访问基地址：LOCAL 场景一般填后端 static 地址
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/static
# 本地上传目录：相对 apps/api 工作目录
STORAGE_UPLOAD_DIR=./uploads
# 签名 URL 过期秒数：下载临时链接有效期，常用 300~1800
STORAGE_SIGNED_EXPIRES_IN_SECONDS=900
# S3 区域：使用 AWS/S3 兼容服务时填写，如 ap-southeast-1
S3_REGION=
# S3 访问端点：自建 MinIO 需填写 http://主机:端口
S3_ENDPOINT=
# S3 Access Key：对象存储访问账号
S3_ACCESS_KEY_ID=
# S3 Secret Key：对象存储访问密码
S3_SECRET_ACCESS_KEY=
# S3 临时会话令牌：使用临时凭证时填写，长期密钥可留空
S3_SESSION_TOKEN=
# S3 路径风格：MinIO 通常填 true，AWS S3 通常填 false
S3_FORCE_PATH_STYLE=false
# 是否启用邮件：true 开启，false 关闭
MAIL_ENABLED=false
# 邮件服务提供商：当前默认 SMTP
MAIL_PROVIDER=SMTP
# 发件人名称：收件箱中显示的发件人昵称
MAIL_FROM_NAME=Enterprise Blog
# 发件人邮箱地址：如 no-reply@example.com
MAIL_FROM_ADDRESS=
# SMTP 主机：如 smtp.qq.com / smtp.gmail.com
MAIL_SMTP_HOST=
# SMTP 端口：常见 465(SSL) 或 587(TLS)
MAIL_SMTP_PORT=587
# SMTP 是否 SSL：465 常填 true，587 常填 false
MAIL_SMTP_SECURE=false
# SMTP 用户名：通常是完整邮箱地址
MAIL_SMTP_USER=
# SMTP 密码/授权码：邮箱平台生成的 SMTP 凭据
MAIL_SMTP_PASS=
# 邮件失败重试次数：建议 1~5
MAIL_RETRY_COUNT=3
# 邮件重试退避毫秒：每次重试等待时间
MAIL_RETRY_BACKOFF_MS=800
# 静态导出目录：站点静态化文件输出位置
STATIC_OUTPUT_DIR=./static-export
# 备份输出目录：数据库/文件备份输出位置
BACKUP_OUTPUT_DIR=./backups
# 运维确认密钥：高风险操作二次确认密钥，生产必须设置
OPS_CONFIRM_SECRET=
# 运维确认有效期秒数：确认票据过期时间
OPS_CONFIRM_TTL_SECONDS=900
# 登录验证码密钥：必须替换为随机字符串，避免验证码被伪造
LOGIN_CAPTCHA_SECRET=change-me-login-captcha-secret
# 登录失败封禁阈值：连续失败超过该值触发封禁
LOGIN_MAX_FAILURES=5
# 登录封禁分钟数：触发封禁后的持续时间
LOGIN_BLOCK_MINUTES=15
# 每分钟限流阈值：单客户端每分钟允许的请求数
RATE_LIMIT_PER_MINUTE=180
# CC 突发阈值：短窗口内超过该值视为突发流量
CC_BURST_THRESHOLD=80
# CC 突发窗口秒数：用于突发检测的时间窗口
CC_BURST_WINDOW_SECONDS=10
# CC 自动封禁分钟数：命中规则后的自动封禁时长
CC_AUTO_BAN_MINUTES=10
# 是否启用登录安全告警邮件：true 开启，false 关闭
SECURITY_LOGIN_ALERT_EMAIL_ENABLED=false
# 是否强制 HTTPS：本地开发通常 false，生产建议 true（反向代理配合）
ENFORCE_HTTPS=false
# Redis 连接串：格式 redis://主机:端口，默认本机 6379
REDIS_URL=redis://127.0.0.1:6379
# Redis 键前缀：多环境隔离建议带项目名和环境名
REDIS_KEY_PREFIX=enterprise_blog
# Redis 健康探测间隔秒数：定时检测 Redis 可用性
REDIS_HEALTH_PROBE_INTERVAL_SECONDS=60
# Redis 降级告警节流秒数：避免短时间重复告警
REDIS_DEGRADED_ALERT_THROTTLE_SECONDS=900
# Redis SLA 统计窗口小时数：用于可用性统计
REDIS_SLA_WINDOW_HOURS=24
# 是否启用安全探测告警邮件：true 开启，false 关闭
SECURITY_PROBE_ALERT_EMAIL_ENABLED=false
# 是否启用 GeoIP：true 开启来源地识别，false 关闭
GEOIP_ENABLED=true
# GeoIP 授权密钥：使用自动更新时按供应商要求填写
GEOIP_LICENSE_KEY=
# GeoIP 自动更新间隔小时：如 24 表示每天更新一次
GEOIP_AUTO_UPDATE_INTERVAL_HOURS=24

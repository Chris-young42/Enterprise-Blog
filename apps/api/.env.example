NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_NAME=Enterprise Blog API
DATABASE_URL="mysql://root:root@127.0.0.1:3306/enterprise_blog?schema=public"
JWT_ACCESS_SECRET="please-change-access-secret"
JWT_REFRESH_SECRET="please-change-refresh-secret"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_ACCESS_EXPIRES_IN_SECONDS=86400
BCRYPT_SALT_ROUNDS=12
STORAGE_PROVIDER=LOCAL
STORAGE_BUCKET=enterprise-blog
STORAGE_PUBLIC_BASE_URL=http://localhost:3000/static
STORAGE_UPLOAD_DIR=./uploads
STORAGE_SIGNED_EXPIRES_IN_SECONDS=900
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_FORCE_PATH_STYLE=false

{
  "name": "enterprise-blog-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @enterprise-blog/web --filter @enterprise-blog/api dev",
    "dev:env": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-env.ps1",
    "dev:env:init": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-env.ps1 -InitDb",
    "dev:env:sh": "bash ./scripts/dev-env.sh",
    "dev:env:sh:init": "bash ./scripts/dev-env.sh --init-db",
    "dev:web": "pnpm --filter @enterprise-blog/web dev",
    "dev:api": "pnpm --filter @enterprise-blog/api dev",
    "db:up": "docker compose up -d mysql minio redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:ps": "docker compose ps",
    "db:reset": "docker compose down -v",
    "db:init": "pnpm --filter @enterprise-blog/api prisma:migrate && pnpm --filter @enterprise-blog/api prisma:seed",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "format": "prettier --write .",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.46.1"
  }
}
